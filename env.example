# Database Configuration
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3001"

# Authentication (NextAuth.js)
# ⚠️ IMPORTANT: NEXTAUTH_URL must match your local port (3001) or production URL exactly!
# This is used for all authentication redirects (sign in, sign out, callbacks)
AUTH_SECRET="your-super-secret-random-string-here"
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-super-secret-random-string-here"

# Application Configuration
APP_URL="http://localhost:3001"
VERCEL_ENV="development"

RESEND_API_KEY="xxxxxx"
OPENROUTER_API_KEY="xxxxxx"
CRON_SECRET="your-super-secret-random-string-here"

# ============================================================================
# PAYMENTS (OPTIONAL) - Get from Nouvobanq
# 🎉 FREE MODE: Comment out to run in free testing mode!
# ============================================================================
# MPGS_MERCHANT_ID="your_merchant_id"
# MPGS_API_PASSWORD="your_api_password"
# MPGS_GATEWAY_URL="https://eu-gateway.mastercard.com"
# ⚠️ MPGS_GATEWAY_URL must be the gateway HOST only — no path suffix (no /ma, no trailing slash)
# Test:  https://test-gateway.mastercard.com
# Prod:  https://eu-gateway.mastercard.com  (or the region assigned by Nouvobanq)
# MPGS_WEBHOOK_SECRET="your_webhook_secret"
# MPGS_SUCCESS_URL="http://localhost:3001/digital/account?payment=success"
# MPGS_CANCEL_URL="http://localhost:3001/digital/compliance-watch?payment=cancelled"
# For production, use your live domain and HTTPS, e.g.:
# MPGS_SUCCESS_URL="https://www.fermidas.com/digital/account?payment=success"
# MPGS_CANCEL_URL="https://www.fermidas.com/digital/compliance-watch?payment=cancelled"
#
# 👉 Contact: Nouvobanq merchant services
# 👉 Request: MPGS Hosted Checkout credentials
# 👉 Integration Guide: https://na-gateway.mastercard.com/api/documentation/integrationGuidelines/index.htm
# 👉 Integration Options: Hosted Checkout, Hosted Session, or Direct API
# 👉 Start with test credentials (sandbox environment)
# 
# Requirements:
# 1. Bank account with Nouvobanq
# 2. Company website (this application)
# 3. Developer/IT person for integration
# 4. Test credentials will be provided by the bank
# 5. After successful testing, move to production environment
# 
# When commented out: Product runs in FREE MODE for testing
# When configured: Product requires subscription/payment

# Training Course Video and Poster Image Blob Storage
BLOB_STORE_ID="************"
BLOB_READ_WRITE_TOKEN="************"

# Recommended for most uses
DATABASE_URL="xxxxxx"

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED="xxxxxx"

# Parameters for constructing your own connection string
PGHOST="xxxxxx"
PGHOST_UNPOOLED="xxxxxx"
PGUSER="xxxxxx"
PGDATABASE="xxxxxx"
PGPASSWORD="xxxxxx"

# Parameters for Vercel Postgres Templates
POSTGRES_URL="xxxxxx"
POSTGRES_URL_NON_POOLING="xxxxxx"
POSTGRES_USER="xxxxxx"
POSTGRES_HOST="xxxxxx"
POSTGRES_PASSWORD="xxxxxx"
POSTGRES_DATABASE="xxxxxx"
POSTGRES_URL_NO_SSL="xxxxxx"
POSTGRES_PRISMA_URL="xxxxxx"

# Neon Auth environment variables for Next.js
NEXT_PUBLIC_STACK_PROJECT_ID="xxxxxx"
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY="xxxxxx"
STACK_SECRET_SERVER_KEY="xxxxxx"