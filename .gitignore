# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/mock-mpgs
/mock-admin
/admin-dashboard

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# migrations — only track .sql files needed for production schema
/migrations/*

.cursor

# Snyk Security Extension - AI Rules (auto-generated)
.cursor/rules/snyk_rules.mdc

# Exclude all markdown files except README.md
*.sql
*.md
!README.md

# migrations — track .sql migration files (override *.sql exclusion above)
!/migrations/*.sql

# Local test/utility scripts — not for production
/scripts/backfill-enrollment-expiry.ts
/scripts/seed-test-course.ts
